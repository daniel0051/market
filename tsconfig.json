{
  "compilerOptions": {
    "target": "es2018",
    "outDir": "./dist",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*", "vitest.config.mts", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
